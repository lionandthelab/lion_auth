# ============================================================
# lion_auth 표준 환경변수 스키마
# 이 블록을 서비스 저장소 루트의 .env에 추가하고 값을 채운다.
# 값 발급 방법: packages/lion_auth/SETUP.md (브라우저 에이전트 프롬프트 포함)
# 채운 뒤: node scripts/lion_auth_setup.mjs all  → 나머지 설정 전부 자동
# ============================================================

# --- Google (GCP 콘솔 > API 및 서비스 > 사용자 인증 정보) ---
LION_GOOGLE_WEB_CLIENT_ID=
LION_GOOGLE_WEB_CLIENT_SECRET=
LION_GOOGLE_ANDROID_CLIENT_ID=
LION_GOOGLE_IOS_CLIENT_ID=

# --- Kakao (Kakao Developers > 앱 > 앱 키 / 보안) ---
LION_KAKAO_NATIVE_APP_KEY=
LION_KAKAO_JS_KEY=
LION_KAKAO_REST_API_KEY=
LION_KAKAO_CLIENT_SECRET=

# --- Naver (Naver Developers > 애플리케이션 정보) ---
LION_NAVER_CLIENT_ID=
LION_NAVER_CLIENT_SECRET=
# 웹 리다이렉트 복귀 주소 (선택, 미지정 시 현재 페이지 URL 사용)
LION_NAVER_WEB_REDIRECT_URI=

# --- Supabase Management API (대시보드 클릭 없이 자동 설정용) ---
# https://supabase.com/dashboard/account/tokens 에서 발급 (sbp_ 로 시작)
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# ============================================================
# 메시징 서브모듈 (알림톡 · 푸시) — 아래는 lion-notify Edge Function 전용 시크릿.
# 클라이언트(dart-define)로는 절대 넘기지 않는다. LION_FCM_WEB_VAPID_KEY만 예외(공개키).
# 값 발급 방법: SETUP.md 1-E(Solapi), 1-F(Firebase)
# 채운 뒤: node scripts/lion_auth_setup.mjs messaging  → 시크릿 주입 + 함수 배포
# ============================================================

# --- Solapi (알림톡 + SMS/LMS 자동 대체) — 서버 전용 ---
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=          # 등록·인증된 발신번호 (숫자만, 예: 0212345678)
SOLAPI_PFID=            # 카카오 발신프로필 ID (PF... — 채널 연동 후 발급)

# --- FCM (푸시) — 서버 전용 ---
FCM_PROJECT_ID=         # Firebase 프로젝트 ID
FCM_SERVICE_ACCOUNT=    # 서비스계정 JSON 원문 또는 base64 (한 줄) — 서버 시크릿

# --- FCM 웹 푸시 공개키 (클라이언트 주입 OK — dart-define으로 전달) ---
LION_FCM_WEB_VAPID_KEY=
